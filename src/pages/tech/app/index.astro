---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import VirtualPhone from '../../../components/VirtualPhone.tsx';
import { getCollection } from 'astro:content';

const allApps = await getCollection('apps');

function extractSlug(id: string) {
  return id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, '');
}

const apps = allApps
  .filter(a => a.data.embed)
  .map(a => ({
    id: extractSlug(a.id),
    title: a.data.title,
    icon: a.data.icon ?? '🚀',
    embed: a.data.embed!,
  }));
---

<BaseLayout title="App · Tech · 林雨夜" description="交互式 H5 与 Demo">
  <main class="min-h-screen px-4 sm:px-6 py-8 sm:py-12 flex flex-col items-center">
    <div class="mb-6 text-xs text-terminal-muted text-center">
      <a href="/" class="link-glow">~</a>
      <span class="mx-1">/</span>
      <a href="/tech/" class="link-glow">tech</a>
      <span class="mx-1">/</span>
      <span class="text-terminal-text">app</span>
    </div>

    <VirtualPhone client:load apps={apps} />

    <footer class="text-center text-xs text-terminal-muted py-8 mt-4">
      <span class="prompt-symbol">❯ </span>
      <span class="cmd-text">cd ..</span>
      <span class="mx-2">·</span>
      <a href="/tech/" class="link-glow">← back to tech</a>
    </footer>
  </main>
</BaseLayout>
