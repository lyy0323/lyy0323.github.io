---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map(app => ({
    params: { slug: app.id.replace(/\.mdx?$/, '') },
    props: { app },
  }));
}

const { app } = Astro.props;
const { Content } = await render(app);
const slug = app.id.replace(/\.mdx?$/, '');
---

<BaseLayout title={`${app.data.title} · Tech`} description={app.data.description}>
  <main class="min-h-screen px-4 sm:px-6 py-12 sm:py-20 max-w-3xl mx-auto">
    <div class="mb-8 text-xs text-terminal-muted">
      <a href="/" class="link-glow">~</a>
      <span class="mx-1">/</span>
      <a href="/tech/" class="link-glow">tech</a>
      <span class="mx-1">/</span>
      <a href="/tech/app/" class="link-glow">app</a>
      <span class="mx-1">/</span>
      <span class="text-terminal-text">{slug}</span>
    </div>

    <div class="terminal-window mb-8">
      <div class="terminal-header">
        <div class="terminal-dot bg-red-500"></div>
        <div class="terminal-dot bg-yellow-500"></div>
        <div class="terminal-dot bg-green-500"></div>
        <span class="ml-3 text-xs text-terminal-muted">{slug}</span>
      </div>
      <div class="p-5 sm:p-6">
        <div class="flex items-start gap-3 mb-4">
          <span class="text-2xl">🚀</span>
          <div>
            <h1 class="text-lg font-semibold text-terminal-amber font-lxgw">{app.data.title}</h1>
            <p class="text-sm text-terminal-muted font-lxgw mt-1">{app.data.description}</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 text-xs border-t border-terminal-border pt-4 mb-4">
          <div><span class="text-terminal-muted">date: </span><span class="text-terminal-text">{app.data.date}</span></div>
          {app.data.url && (
            <a href={app.data.url} target="_blank" rel="noopener noreferrer" class="link-glow">→ try it live</a>
          )}
        </div>
        <div class="flex flex-wrap gap-1.5">
          {app.data.tags.map((tag: string) => (
            <span class="text-[10px] px-1.5 py-0.5 rounded border border-terminal-border bg-terminal-bg text-terminal-cyan/70">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="terminal-window">
      <div class="terminal-header">
        <div class="terminal-dot bg-red-500"></div>
        <div class="terminal-dot bg-yellow-500"></div>
        <div class="terminal-dot bg-green-500"></div>
        <span class="ml-3 text-xs text-terminal-muted">content</span>
      </div>
      <div class="p-5 sm:p-6 prose prose-invert prose-sm max-w-none
        prose-headings:text-terminal-amber prose-headings:font-lxgw prose-headings:font-semibold
        prose-p:text-terminal-text prose-p:font-lxgw prose-p:leading-relaxed
        prose-strong:text-terminal-green
        prose-a:text-terminal-cyan prose-a:no-underline hover:prose-a:text-terminal-green
        prose-li:text-terminal-text prose-li:font-lxgw
        prose-code:text-terminal-pink prose-code:bg-terminal-bg prose-code:px-1 prose-code:rounded
        prose-hr:border-terminal-border">
        <Content />
      </div>
    </div>

    <div class="mt-8 text-xs text-terminal-muted">
      <span class="prompt-symbol">❯ </span><span class="cmd-text">cd ..</span>
      <span class="mx-2">·</span>
      <a href="/tech/" class="link-glow">← back to tech</a>
    </div>
  </main>
</BaseLayout>
